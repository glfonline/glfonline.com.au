{
	"buildCommand": "react-router build",
	"outputDirectory": "build/client",
	"functions": {
		"build/server/index.js": {
			"runtime": "nodejs20.x"
		}
	},
	"routes": [
		{
			"src": "/assets/(.*)",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/(.*)",
			"dest": "/build/server/index.js"
		}
	]
}
