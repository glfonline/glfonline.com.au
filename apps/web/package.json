{
	"name": "@glfonline/web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"build": "mkdir -p build/client/.vite && react-router build",
		"check:deps": "pnpm --dir ../.. exec knip --workspace apps/web --no-exit-code --dependencies",
		"check:exports": "pnpm --dir ../.. exec knip --workspace apps/web --no-exit-code --exports",
		"check:format": "pnpm biome format",
		"check:lint": "pnpm biome lint",
		"check:types": "react-router typegen && tsc --noEmit",
		"clean": "pnpm clean:outputs && rm -rf node_modules",
		"clean:outputs": "rm -rf .cache && rm -rf .turbo && rm -rf api && rm -rf public/build",
		"dev": "react-router dev",
		"fix:deps": "pnpm --dir ../.. exec knip --workspace apps/web --fix --fix-type dependencies --no-exit-code",
		"fix:exports": "pnpm --dir ../.. exec knip --workspace apps/web --fix --fix-type exports --no-exit-code",
		"fix:format": "pnpm biome format --write",
		"fix:lint": "pnpm biome lint --write",
		"start": "NODE_OPTIONS='--import ./instrumentation.server.mjs' dotenv -e .env -- react-router-serve ./build/server/index.js",
		"test:all": "pnpm test:unit && pnpm test:browser",
		"test:browser": "vitest run --config=vitest.browser.config.ts",
		"test:coverage": "vitest run --coverage --config vitest.unit.config.ts",
		"test:ui": "vitest --ui",
		"test:unit": "vitest run --config vitest.unit.config.ts"
	},
	"dependencies": {
		"@algolia/client-search": "catalog:",
		"@glfonline/sanity-client": "workspace:^",
		"@glfonline/shopify-client": "workspace:^",
		"@heroicons/react": "catalog:",
		"@paypal/react-paypal-js": "catalog:",
		"@portabletext/react": "catalog:",
		"@react-router/node": "catalog:",
		"@sanity/asset-utils": "catalog:",
		"@sanity/image-url": "catalog:",
		"@sentry/react-router": "catalog:",
		"@tanstack/query-async-storage-persister": "catalog:",
		"@tanstack/query-core": "catalog:",
		"@tanstack/react-form": "catalog:",
		"@tanstack/react-form-remix": "catalog:",
		"@tanstack/react-query": "catalog:",
		"@tanstack/react-query-devtools": "catalog:",
		"@tanstack/react-query-persist-client": "catalog:",
		"@unpic/react": "catalog:",
		"@vercel/node": "catalog:",
		"algoliasearch": "catalog:",
		"class-variance-authority": "catalog:",
		"clsx": "catalog:",
		"dedent": "catalog:",
		"emery": "catalog:",
		"is-ip": "catalog:",
		"isbot": "catalog:",
		"react": "catalog:",
		"react-aria-components": "catalog:",
		"react-dom": "catalog:",
		"react-intersection-observer": "catalog:",
		"react-router": "catalog:",
		"react-turnstile": "catalog:",
		"remeda": "catalog:",
		"remix-utils": "catalog:",
		"resend": "catalog:",
		"tailwind-merge": "catalog:",
		"tiny-invariant": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@glfonline/tsconfig": "workspace:^",
		"@react-router/dev": "catalog:",
		"@react-router/fs-routes": "catalog:",
		"@react-router/serve": "catalog:",
		"@tailwindcss/forms": "catalog:",
		"@tailwindcss/typography": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vercel/react-router": "catalog:",
		"@vitejs/plugin-react": "catalog:",
		"@vitest/browser-playwright": "catalog:",
		"dotenv-cli": "catalog:",
		"knip": "catalog:",
		"playwright": "catalog:",
		"tailwindcss": "catalog:",
		"tailwindcss-animate": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:",
		"vitest-browser-react": "catalog:"
	}
}
