{
	"name": "@glfonline/root",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"build:cms": "turbo run build --filter=@glfonline/cms...",
		"build:packages": "turbo run build --filter=./packages/*",
		"build:web": "turbo run build --filter=@glfonline/web...",
		"check": "turbo run check",
		"check:deps": "turbo run check:deps",
		"check:exports": "turbo run check:exports",
		"check:format": "turbo run check:format",
		"check:lint": "turbo run check:lint",
		"check:types": "turbo run check:types",
		"clean": "pnpm run -r clean && rm -rf node_modules",
		"clean:outputs": "pnpm run -r clean:outputs && rm -rf node_modules/.cache/",
		"deploy:cms": "pnpm --filter @glfonline/cms run deploy && pnpm run generate",
		"dev": "turbo run dev",
		"dev:cms": "turbo run dev --filter=@glfonline/cms...",
		"dev:packages": "turbo run dev --filter=./packages/*",
		"dev:web": "turbo run dev --filter=@glfonline/web...",
		"fix": "turbo run fix",
		"fix:deps": "turbo run fix:deps",
		"fix:exports": "turbo run fix:exports",
		"fix:format": "turbo run fix:format",
		"fix:lint": "turbo run fix:lint",
		"fresh": "pnpm run clean && pnpm install",
		"generate": "turbo run generate",
		"postinstall": "manypkg check",
		"preinstall": "pnpm dlx only-allow pnpm",
		"sort:packages": "pnpm dlx sort-package-json 'package.json' './apps/*/package.json' './packages/*/package.json'",
		"test": "turbo run test:browser test:e2e test:unit",
		"test:browser": "turbo run test:browser",
		"test:e2e": "turbo run test:e2e",
		"test:unit": "turbo run test:unit"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@glfonline/tsconfig": "workspace:^",
		"@manypkg/cli": "catalog:",
		"@playwright/test": "catalog:",
		"knip": "catalog:",
		"turbo": "catalog:",
		"turbo-ignore": "catalog:",
		"typescript": "catalog:"
	},
	"engines": {
		"node": ">=22",
		"pnpm": ">=9"
	},
	"packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
	"manypkg": {
		"defaultBranch": "main",
		"workspaceProtocol": "require"
	}
}
